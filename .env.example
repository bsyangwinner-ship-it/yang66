# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Backend
APP_NAME=Graduate Nutrition Agent API
APP_VERSION=0.1.0
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000"]

# Auth
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# PostgreSQL + pgvector
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/nutrition_agent

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
ENABLE_RULE_FALLBACK=true

# S3 / MinIO
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET_NAME=nutrition-agent
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
REPORT_EXPORT_STORAGE=local
REPORT_EXPORT_PREFIX=reports

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_ENABLED=false
OTEL_SERVICE_NAME=graduate-nutrition-agent-api
PROMETHEUS_ENABLED=true
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Gateway
NGINX_PUBLIC_URL=http://localhost:8080
